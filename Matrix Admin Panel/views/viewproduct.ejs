<%- include('header') %>
<!-- ============================================================== -->
<!-- Page wrapper  -->
<!-- ============================================================== -->
<div class="page-wrapper">
    <!-- ============================================================== -->
    <!-- Bread crumb and right sidebar toggle -->
    <!-- ============================================================== -->
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Products</h4>
                <div class="ml-auto text-right">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="#">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Products</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
    <!-- ============================================================== -->
    <!-- End Bread crumb and right sidebar toggle -->
    <!-- ============================================================== -->
    <!-- ============================================================== -->
    <!-- Container fluid  -->
    <!-- ============================================================== -->
    <div class="container-fluid">
        <!-- ============================================================== -->
        <!-- Start Page Content -->
        <!-- ============================================================== -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title m-b-0">All Products</h5>
                        <a href="/product/add-product" class="btn btn-primary mb-3">Add New Product</a>
                    </div>
                    <table class="table">
                        <thead>
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Product Name</th>
                            <th scope="col">Category</th>
                            <th scope="col">Subcategory</th>
                            <th scope="col">Extracategory</th>
                            <th scope="col">Price</th>
                            <th scope="col">Quantity</th>
                            <th scope="col">Image</th>
                            <th scope="col">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                                <% products.forEach((product, i)=>{ %>
                                    <tr>
                                        <th scope="row"><%= i+1 %></th>
                                        <td><%= product.pname %></td>
                                        <td><%= product.category ? product.category.cname : 'N/A' %></td>
                                        <td><%= product.subcategory ? product.subcategory.scname : 'N/A' %></td>
                                        <td><%= product.extracategory ? product.extracategory.ecname : 'N/A' %></td>
                                        <td>$<%= product.price %></td>
                                        <td><%= product.quantity %></td>
                                        <td>
                                            <% if(product.productImage) { %>
                                                <img src="<%= product.productImage %>" alt="<%= product.pname %>" class="img-thumbnail" style="aspect-ratio: 1/1; object-fit: cover; width: 60px">
                                            <% } else { %>
                                                No Image
                                            <% } %>
                                        </td>
                                        <td>
                                            <a href="/product/edit-product/<%=product._id%>" class="btn btn-sm btn-warning">Edit</a>
                                            <a href="/product/delete-product/<%=product._id%>" class="btn btn-sm btn-danger ml-2" onclick="return confirm('Are you sure you want to delete this product?')">Delete</a>
                                        </td>
                                    </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End PAge Content -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Right sidebar -->
        <!-- ============================================================== -->
        <!-- .right-sidebar -->
        <!-- ============================================================== -->
        <!-- End Right sidebar -->
        <!-- ============================================================== -->
    </div>
    <!-- ============================================================== -->
    <!-- End Container fluid  -->
    <!-- ============================================================== -->
<%- include('footer') %>